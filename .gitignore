# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/

# IDEs & OS
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 忽略所有点开头的目录（.git 除外，由 Git 自动处理）
.*/

# Data directory (keep directory structure, ignore all contents)
data/*
!data/.gitkeep

# Logs (already covered by data/* above, but keep for clarity)
*.log
data/logs/

# Session and credential files
*.pkl
session.pkl

# Node.js
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 允许前端的默认环境配置（包含必要的开发服务器配置）
# 注意：这些文件包含的是开发服务器的基础配置，不含敏感信息
!frontend/.env
!frontend/.env.development

# Testing
coverage/
.coverage
htmlcov/

# MyPy
.dmypy.json
dmypy.json
